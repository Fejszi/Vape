#include "vpdp.h"
uint8_t val;
vpdp display(2, 3, 4, 5, 6);
void setup(){
  
}

void loop() {
  int x = 1;
  for (int i = 0; i > -1; i = i + x) {
    val = i;
    
    if (x == -1){
      display.percentage(true);  //enable the percentage icon
      display.raindrop(false); //disable the raindrop icon
    }
    else{
      display.percentage(false); //disable the percentage icon
      display.raindrop(true);  //enable the raindrop icon
    }
    
    display.numbers(val);  //displays the variable inside the parantheses
    
    if (i == 199) {
      x = -1;
    }
  }
}
